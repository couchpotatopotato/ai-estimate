# ── LLM ──────────────────────────────────────────────────────────────────────
# Get your free key at: https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-flash

# ── DB toggle: local | cloud ──────────────────────────────────────────────────
DB_MODE=local

# ── Local Postgres (DB_MODE=local) ───────────────────────────────────────────
DB_HOST=db
DB_PORT=5432
DB_NAME=beacon
DB_USER=readonly_user
DB_PASSWORD=your_password_here

# ── Cloud SQL (DB_MODE=cloud) ─────────────────────────────────────────────────
# Enable public IP on your instance: GCP Console → Cloud SQL → Connections → Networking
# DB_MODE=cloud
# DATABASE_URL=postgresql://your_user:your_password@your_public_ip:5432/your_db_name

# ── Steering files ────────────────────────────────────────────────────────────
STEERING_DIR=/app/steering
