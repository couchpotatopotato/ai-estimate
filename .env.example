# ── LLM ──────────────────────────────────────────────────────────────────────
# Get your free key at: https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-flash

# ── DB toggle: local | cloud ──────────────────────────────────────────────────
DB_MODE=local

# ── Local Postgres (DB_MODE=local) ───────────────────────────────────────────
DB_HOST=db
DB_PORT=5432
DB_NAME=beacon
DB_USER=readonly_user
DB_PASSWORD=your_password_here

# ── Cloud SQL (DB_MODE=cloud) ─────────────────────────────────────────────────
# DB_HOST=cloud-sql-proxy
# DB_PORT=5432
# DB_NAME=your_cloud_db_name
# DB_USER=your_cloud_db_user
# DB_PASSWORD=your_cloud_db_password
# CLOUD_SQL_INSTANCE=your_project:your_region:your_instance

# ── Steering files ────────────────────────────────────────────────────────────
STEERING_DIR=/app/steering
